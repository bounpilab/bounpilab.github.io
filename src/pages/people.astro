---
import MainLayout from '../layouts/MainLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getCollection } from 'astro:content';

const allPeople = (await getCollection('people')).filter(person =>
  ['pi', 'student', 'alumni'].includes(person.data.category)
);

const principalInvestigators = allPeople
  .filter(person => person.data.category === 'pi')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const phdStudents = allPeople
  .filter(
    person =>
      person.data.category === 'student' && person.data.title === 'PhD Student'
  )
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const msStudents = allPeople
  .filter(
    person =>
      person.data.category === 'student' && person.data.title === 'MS Student'
  )
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const alumni = allPeople
  .filter(person => person.data.category === 'alumni')
  .sort((a, b) => {
    if (a.data.graduationYear && b.data.graduationYear) {
      return b.data.graduationYear - a.data.graduationYear;
    }
    return (a.data.order ?? 0) - (b.data.order ?? 0);
  });

const sectionHeadingClass =
  'text-sm font-bold tracking-widest uppercase text-gray-900 mb-6';
---

<MainLayout title="People - PILAB">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-primary mb-12 text-center">
      Our Team
    </h1>

    <section class="mb-16 max-w-4xl mx-auto">
      <h2 class={sectionHeadingClass}>Faculty Members</h2>
      <div class="flex flex-col gap-6">
        {principalInvestigators.map(pi => (
          <PersonCard entry={pi} />
        ))}
      </div>
    </section>

    <section class="mb-16 max-w-4xl mx-auto">
      <h2 class={sectionHeadingClass}>PhD Students</h2>
      <div class="flex flex-col gap-6">
        {phdStudents.map(student => (
          <PersonCard entry={student} />
        ))}
      </div>
    </section>

    <section class="mb-16 max-w-4xl mx-auto">
      <h2 class={sectionHeadingClass}>MS Students</h2>
      <div class="flex flex-col gap-6">
        {msStudents.map(student => (
          <PersonCard entry={student} />
        ))}
      </div>
    </section>

    <section class="mb-16 max-w-4xl mx-auto">
      <h2 class={sectionHeadingClass}>Alumni</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {alumni.map(alum => (
          <PersonCard entry={alum} />
        ))}
      </div>
    </section>
  </div>
</MainLayout>
