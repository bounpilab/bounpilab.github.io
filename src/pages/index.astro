---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { format } from 'date-fns';

// Get featured papers
const papers = await getCollection('papers', (paper) => paper.data.featured === true);
papers.sort((a, b) => b.data.year - a.data.year);
const featuredPapers = papers.slice(0, 3);

// Get featured projects
const projects = await getCollection('projects', (project) => project.data.featured === true);
projects.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));
const featuredProjects = projects.slice(0, 3);

// Get latest news
const news = await getCollection('news');
news.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestNews = news.slice(0, 3);

// Get highlights
const highlights = await getCollection('highlights');
highlights.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

// Helper function to get proper image path with base URL
function getImagePath(path: string) {
  if (path.startsWith('http')) return path;
  if (path.startsWith('/')) {
    return import.meta.env.BASE_URL + path.substring(1);
  }
  return path;
}

// Format date function
function formatDate(date) {
  return format(new Date(date), 'MMMM d, yyyy');
}
---

<MainLayout title="PILAB - Perceptual Intelligence Laboratory">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-primary to-primary-dark text-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-5xl font-bold mb-4">PILAB</h1>
        <p class="text-2xl mb-6">Perceptual Intelligence Laboratory</p>

        <p class="text-xl mb-10">
          We advance the frontiers of computer vision, biometrics, and 3D visual understanding.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/projects"
            class="bg-white text-primary font-bold py-3 px-6 rounded-lg hover:bg-gray-100 transition-colors"
          >
            Our Projects
          </a>
          <a
            href="/papers"
            class="bg-transparent border-2 border-white text-white font-bold py-3 px-6 rounded-lg hover:bg-white/10 transition-colors"
          >
            Research Papers
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-primary mb-8 text-center">
          Welcome to PILAB
