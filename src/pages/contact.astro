---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact - PILAB">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-primary mb-12 text-center">Contact Us</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Information -->
      <div>
        <h2 class="text-2xl font-bold text-primary mb-6">Get in Touch</h2>
        
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-semibold mb-2">Address</h3>
            <p class="text-gray-700">
              Computer Engineering Department<br />
              Boğaziçi University<br />
              34342 Bebek, Istanbul<br />
              Türkiye
            </p>
          </div>
          
          <div>
            <h3 class="text-xl font-semibold mb-2">Contact Details</h3>
            <p class="text-gray-700">
              <span class="font-medium">Tel:</span> +90 212 359 45 23-24<br />
              <span class="font-medium">Fax:</span> +90 212 287 2461<br />
              <!--<span class="font-medium">Email:</span> <a href="mailto:tabilab@boun.edu.tr" class="text-primary-light hover:underline">tabilab@boun.edu.tr</a>-->
            </p>
          </div>
          <!--
          <div>
            <h3 class="text-xl font-semibold mb-2">Social Media</h3>
            <div class="flex space-x-4">
              <a href="https://twitter.com/bountabilab" target="_blank" rel="noopener noreferrer" class="text-primary-light hover:text-primary-dark">
                Twitter
              </a>
              <a href="https://github.com/bounpilab" target="_blank" rel="noopener noreferrer" class="text-primary-light hover:text-primary-dark">
                GitHub
              </a>
              <a href="https://linkedin.com/company/bountabilab" target="_blank" rel="noopener noreferrer" class="text-primary-light hover:text-primary-dark">
                LinkedIn
              </a>
            </div>
          </div>
	  -->
        </div>
        
        <div class="mt-8">
          <h3 class="text-xl font-semibold mb-4">Location</h3>
          <div class="bg-gray-200 rounded-lg overflow-hidden h-64">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3007.331679854733!2d29.0511!3d41.0857!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDHCsDA1JzA4LjUiTiAyOcKwMDMnMDQuMCJF!5e0!3m2!1sen!2str!4v1620000000000!5m2!1sen!2str" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
      
      <!-- Photos Section -->
      <div class="space-y-8">
        <!-- Lab Photo -->
        <div>
 	<div class="bg-gray-50 rounded-lg">
   	    <p class="text-gray-700 text-lg">
                Our lab is located in the Computer Engineering Department at Boğaziçi University's Kuzey Campus. 
             </p>
	  </div>
          <!--<h3 class="text-xl font-semibold mb-4">Boğaziçi University</h3>--> 
          <div class="rounded-lg overflow-hidden shadow-lg">
            <img 
              src="/images/guney.jpg" 
              class="w-full h-64 object-cover hover:scale-105 transition-transform duration-300"
              onerror="this.src='/images/placeholder-lab.jpg'; this.onerror=null;"
            />
          </div>
        </div>

        <!-- Kuzey Building Photo -->
        <div>
          <div class="rounded-lg overflow-hidden shadow-lg">
            <img 
              src="/images/kuzey.jpg" 
              alt="Kuzey Building"
              class="w-full h-64 object-cover object-[center_70%] hover:scale-105 transition-transform duration-300"
              onerror="this.src='/images/placeholder-lab.jpg'; this.onerror=null;"
            />
          </div>
        </div>
	<!--
        <div class="bg-gray-50 p-6 rounded-lg">
          <p class="text-gray-700 text-lg">
            Our lab is located in the Computer Engineering Department at Boğaziçi University's Kuzey Campus. 
            We welcome collaborations and visits from researchers interested in Natural Language Processing 
            and Machine Learning.
          </p>
        </div>
	-->
      </div>
    </div>
  </div>
</MainLayout> 