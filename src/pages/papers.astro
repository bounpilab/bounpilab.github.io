---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// Get all papers and sort by year (descending)
const papers = await getCollection('papers');
papers.sort((a, b) => b.data.year - a.data.year);

// Group papers by year
const papersByYear = papers.reduce((acc, paper) => {
  const year = paper.data.year;
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(paper);
  return acc;
}, {});

// Get years in descending order
const years = Object.keys(papersByYear).sort((a, b) => Number(b) - Number(a));
const defaultYear = years[0];
---

<MainLayout title="Papers - PILAB">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-primary mb-12 text-center">Publications</h1>

    <div id="papers-year-filter">
      <div
        class="flex flex-wrap justify-center gap-2 mb-10"
        role="tablist"
        aria-label="Filter publications by year"
      >
        {years.map((year) => (
          <button
            type="button"
            id={`year-tab-${year}`}
            role="tab"
            aria-selected={year === defaultYear ? 'true' : 'false'}
            data-year={year}
            class:list={[
              'year-filter-btn px-4 py-2 rounded-md border-2 border-primary font-medium transition-colors',
              'focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
              year === defaultYear
                ? 'bg-primary text-white border-primary hover:bg-primary-dark'
                : 'bg-white text-primary border-primary hover:bg-primary/5',
            ]}
          >
            {year}
          </button>
        ))}
      </div>

      {years.map((year) => (
        <section
          class:list={['paper-year-section mb-12', year !== defaultYear && 'hidden']}
          data-year={year}
          role="tabpanel"
          aria-labelledby={`year-tab-${year}`}
          id={`year-panel-${year}`}
        >
          <h2 class="text-3xl font-bold text-gray-900 mb-6" id={`year-heading-${year}`}>
            {year}
          </h2>
          <div class="space-y-8">
            {papersByYear[year].map((paper) => (
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-semibold text-primary mb-2">
                  <a href={`/papers/${paper.slug}`} class="hover:underline">
                    {paper.data.title}
                  </a>
                </h3>
                <p class="text-gray-700 mb-2">{paper.data.authors}</p>
                <p class="text-gray-600 italic mb-4">{paper.data.venue}</p>

                <div class="mb-4">
                  <p class="text-gray-700">{paper.data.abstract}</p>
                </div>

                <div class="flex flex-wrap gap-4">
                  {paper.data.pdf && (
                    <a
                      href={paper.data.pdf}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-primary-light hover:underline"
                    >
                      <span>PDF</span>
                    </a>
                  )}

                  {paper.data.code && (
                    <a
                      href={paper.data.code}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-primary-light hover:underline"
                    >
                      <span>Code</span>
                    </a>
                  )}

                  <a
                    href={`/papers/${paper.slug}`}
                    class="inline-flex items-center text-primary-light hover:underline"
                  >
                    <span>Read More</span>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <script is:inline>
    (function () {
      var root = document.getElementById('papers-year-filter');
      if (!root) return;

      var buttons = root.querySelectorAll('.year-filter-btn');
      var sections = root.querySelectorAll('.paper-year-section');

      var activeBtn =
        'px-4 py-2 rounded-md border-2 border-primary font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 bg-primary text-white border-primary hover:bg-primary-dark';
      var inactiveBtn =
        'px-4 py-2 rounded-md border-2 border-primary font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 bg-white text-primary border-primary hover:bg-primary/5';

      function selectYear(year) {
        sections.forEach(function (sec) {
          var match = sec.getAttribute('data-year') === year;
          sec.classList.toggle('hidden', !match);
        });
        buttons.forEach(function (btn) {
          var active = btn.getAttribute('data-year') === year;
          btn.setAttribute('aria-selected', active ? 'true' : 'false');
          btn.className = active ? activeBtn : inactiveBtn;
        });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          selectYear(btn.getAttribute('data-year'));
        });
      });
    })();
  </script>
</MainLayout>
